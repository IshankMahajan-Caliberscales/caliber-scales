# Copy to .env and fill in.

# --- Custom /admin panel login (email + password) ---
# AUTH_SECRET signs the session cookie — any long random string.
#   Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ADMIN_PASSWORD_HASH is a scrypt hash ("salt:hash"), never the plain password.
#   Generate: node -e "const c=require('crypto');const p='YOUR_PASSWORD';const s=c.randomBytes(16).toString('hex');console.log(s+':'+c.scryptSync(p,s,64).toString('hex'))"
# AUTH_SECRET=
# ADMIN_EMAIL=info@caliberscales.com
# ADMIN_PASSWORD_HASH=

# --- Keystatic CMS (GitHub mode, used on the deployed site) ---
# These are generated for you when you run `npm run dev`, open /keystatic, and
# complete the "Set up GitHub" flow. Add the same values to your host (Netlify)
# so the live admin panel can authenticate. Local dev uses local mode and needs
# none of these.
# KEYSTATIC_GITHUB_CLIENT_ID=
# KEYSTATIC_GITHUB_CLIENT_SECRET=
# KEYSTATIC_SECRET=
# PUBLIC_KEYSTATIC_GITHUB_APP_SLUG=

# --- Lead delivery (wired in a later phase — see src/pages/api/lead.ts) ---
# LEAD_NOTIFY_EMAIL=
# RESEND_API_KEY=
# LEAD_WEBHOOK_URL=

# --- Analytics (Phase 8) ---
# PUBLIC_GA4_ID=
