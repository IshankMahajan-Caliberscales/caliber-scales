---
/**
 * Weighbridge hub (spec B4/B5) — overview + links to each weighbridge type,
 * with an FAQ (FAQPage schema) and a "need help selecting" CTA band.
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import Section from '@components/ui/Section.astro';
import Hero from '@components/blocks/Hero.astro';
import ProductGrid from '@components/blocks/ProductGrid.astro';
import FeatureList from '@components/blocks/FeatureList.astro';
import FAQAccordion from '@components/blocks/FAQAccordion.astro';
import type { Feature } from '@lib/catalog';
import { WEIGHBRIDGE_TYPES } from '@lib/catalog';
import type { FaqItem } from '@lib/schema';

const benefits: Feature[] = [
  { title: 'Built for heavy-duty operations', detail: 'Engineered for continuous high-tonnage vehicle traffic and harsh industrial conditions.' },
  { title: 'High accuracy & compliance ready', detail: 'Designed for reliable measurement with calibration support for legal-metrology compliance.' },
  { title: 'Customised for your site', detail: 'Multiple configurations including surface mounted, pit type, mobile, track, and unmanned systems.' },
  { title: 'End-to-end execution', detail: 'From design and manufacturing to installation and commissioning.' },
  { title: 'Nationwide service support', detail: 'Installation, calibration, and AMC coverage across 25+ states and Union Territories.' },
  { title: 'Fast deployment capability', detail: 'Quick installation options including instant mobile systems for urgent requirements.' },
];

const faqs: FaqItem[] = [
  {
    q: 'Which type of weighbridge should I choose?',
    a: 'It depends on your site and traffic. Surface mounted (pitless) weighbridges are quick to install and easy to maintain; pit type designs sit flush with the ground and save yard space; instant mobile units install in hours with no foundation; track-type units are an economical option for lighter vehicles; and unmanned automated systems handle weighing round the clock. We can recommend the right fit for your application.',
  },
  {
    q: 'What capacity weighbridge do I need?',
    a: 'Capacity depends on the heaviest fully loaded vehicles you weigh, with a safety margin. Tell us your vehicle types and typical loads and we will size the weighbridge accordingly.',
  },
  {
    q: 'Do you provide installation and calibration?',
    a: 'Yes. As a manufacturer we handle design, installation, calibration, and ongoing maintenance, with service across India.',
  },
];
---

<BaseLayout
  title="Weighbridges"
  metaTitle="Weighbridge Manufacturer — Surface Mounted, Pit Type, Mobile & More | Caliber Scales"
  description="Caliber Scales manufactures surface mounted, pit type, instant mobile, track, and unmanned weighbridges (5–100 MT). Heavy-duty truck scales with installation, calibration, and AMC across India."
  crumbs={[
    { name: 'Products', href: '/products/' },
    { name: 'Weighbridges', href: '/weighbridges/' },
  ]}
  ctaHeading="Need help selecting the right weighbridge?"
  ctaSub="Not sure which configuration fits your site? Speak directly with our engineering team. Share your requirement and we will recommend the most suitable solution based on traffic load, space, and application — with expert guidance and quotation support."
>
  <Hero
    eyebrow="Weighbridges"
    title="Weighbridges built for India's heaviest industrial workloads"
    lede="Surface mounted, pit type, instant mobile, track, and unmanned weighbridges (5–100 MT) — designed, manufactured, installed, and serviced by Caliber Scales for reliable performance in demanding industrial environments."
  />

  <Section title="Weighbridge types" intro="Each weighbridge type is designed for specific site conditions, vehicle traffic, and operational requirements.">
    <ProductGrid items={WEIGHBRIDGE_TYPES} />
  </Section>

  <Section surface title="Why choose a Caliber weighbridge">
    <FeatureList items={benefits} />
  </Section>

  <Section title="Weighbridge FAQs">
    <FAQAccordion faqs={faqs} />
  </Section>
</BaseLayout>
