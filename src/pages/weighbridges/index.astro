---
/**
 * Weighbridge hub (spec B4/B5) — overview + links to each weighbridge type.
 * Carries an FAQ with FAQPage schema for SEO / AI-search. Individual type
 * pages (/weighbridges/pitless/ etc.) are built in Phase 4.
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import Section from '@components/ui/Section.astro';
import Hero from '@components/blocks/Hero.astro';
import ProductGrid from '@components/blocks/ProductGrid.astro';
import FeatureList from '@components/blocks/FeatureList.astro';
import FAQAccordion from '@components/blocks/FAQAccordion.astro';
import type { Feature } from '@lib/catalog';
import { WEIGHBRIDGE_TYPES } from '@lib/catalog';
import type { FaqItem } from '@lib/schema';

const benefits: Feature[] = [
  { title: 'Built for heavy traffic', detail: 'Robust decks and load cells sized for continuous, high-tonnage vehicle weighing.' },
  { title: 'Accurate & compliant', detail: 'Reliable weighing with calibration support for legal-metrology compliance.' },
  { title: 'Configured to your site', detail: 'Pitless, pit-mounted, RCC, instant mobile, track, or unmanned — matched to your layout and traffic.' },
  { title: 'Serviced nationwide', detail: 'Installation, calibration, and AMC across 25+ states and Union Territories.' },
];

const faqs: FaqItem[] = [
  {
    q: 'Which type of weighbridge should I choose?',
    a: 'It depends on your site and traffic. Pitless weighbridges are quick to install and easy to maintain; pit-mounted designs save yard space; RCC decks suit very heavy continuous traffic; instant mobile units install in hours with no foundation; track weighing units are an economical option for four-wheeler vehicles; and unmanned systems automate weighing round the clock. We can recommend the right fit for your application.',
  },
  {
    q: 'What capacity weighbridge do I need?',
    a: 'Capacity depends on the heaviest fully loaded vehicles you weigh, with a safety margin. Tell us your vehicle types and typical loads and we will size the weighbridge accordingly.',
  },
  {
    q: 'Do you provide installation and calibration?',
    a: 'Yes. As a manufacturer we handle design, installation, calibration, and ongoing maintenance, with service across India.',
  },
];
---

<BaseLayout
  title="Weighbridges"
  metaTitle="Weighbridge Manufacturer — Pitless, Pit-Mounted, RCC & More | Caliber Scales"
  description="Caliber Scales manufactures pitless, pit-mounted, RCC, instant mobile, track, and unmanned weighbridges (5–100 MT). Heavy-duty truck scales with installation, calibration, and AMC across India."
  crumbs={[
    { name: 'Products', href: '/products/' },
    { name: 'Weighbridges', href: '/weighbridges/' },
  ]}
>
  <Hero
    eyebrow="Weighbridges"
    title="Weighbridges built for India's heaviest jobs"
    lede="Pitless, pit-mounted, RCC, instant mobile, track, and unmanned weighbridges (5–100 MT) — designed, manufactured, installed, and serviced by Caliber Scales."
  />

  <Section title="Weighbridge types" intro="Each type suits a different site, traffic pattern, and budget.">
    <ProductGrid items={WEIGHBRIDGE_TYPES} />
  </Section>

  <Section surface title="Why a Caliber weighbridge">
    <FeatureList items={benefits} />
  </Section>

  <Section title="Weighbridge FAQs">
    <FAQAccordion faqs={faqs} />
  </Section>
</BaseLayout>
