---
/**
 * /weighbridges/<slug>/ — detail page for each weighbridge-category product.
 * Slug = the product entry id (e.g. "pitless"). Draft entries still render
 * (so hub links never 404) but are noindexed by ProductLayout.
 */
import { getCollection, type CollectionEntry } from 'astro:content';
import ProductLayout from '@layouts/ProductLayout.astro';

export async function getStaticPaths() {
  const products = await getCollection('products');
  return products
    .filter((p) => p.data.category === 'weighbridge')
    .map((p) => ({ params: { slug: p.id }, props: { entry: p } }));
}

const { entry } = Astro.props as { entry: CollectionEntry<'products'> };
---

<ProductLayout entry={entry} />
