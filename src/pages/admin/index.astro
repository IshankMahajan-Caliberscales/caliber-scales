---
/**
 * /admin — the dashboard. Protected: redirects to /admin/login without a valid
 * session. This is the SHELL — each section shows its status and gets wired to
 * live data after deploy (leads datastore, GA4, Google Ads, Search Console, or
 * embedded Looker Studio dashboards).
 */
export const prerender = false;

import AdminLayout from '@layouts/AdminLayout.astro';
import { SESSION_COOKIE, verifySessionToken } from '@lib/auth';
import { getStore } from '@netlify/blobs';

const session = verifySessionToken(Astro.cookies.get(SESSION_COOKIE)?.value);
if (!session) return Astro.redirect('/admin/login/');

const LEAD_STATUSES = ['new', 'contacted', 'quoted', 'won', 'lost', 'invalid'];

interface Lead {
  key: string;
  name: string;
  company: string;
  phone: string;
  requirement: string;
  source?: string;
  status?: string;
  receivedAt: string;
}

// Load recent leads from Netlify Blobs (newest first). Best-effort: if the store
// isn't reachable (e.g. local dev without the Netlify runtime) we show a note
// rather than break the dashboard. We keep each lead's blob key so the dashboard
// can update its status or delete it.
let leads: Lead[] = [];
let leadsError: string | null = null;
try {
  const store = getStore('leads');
  const { blobs } = await store.list();
  const recent = blobs.sort((a, b) => (a.key < b.key ? 1 : -1)).slice(0, 50);
  leads = (
    await Promise.all(
      recent.map(async (b) => {
        const v = (await store.get(b.key, { type: 'json' })) as Omit<Lead, 'key'> | null;
        return v ? { key: b.key, ...v } : null;
      })
    )
  ).filter(Boolean) as Lead[];
} catch (err) {
  leadsError = err instanceof Error ? err.message : 'Lead store unavailable.';
}

const fmtDate = (iso: string) => {
  try {
    return new Date(iso).toLocaleString('en-IN', {
      timeZone: 'Asia/Kolkata',
      dateStyle: 'medium',
      timeStyle: 'short',
    });
  } catch {
    return iso;
  }
};

const cards = [
  {
    title: 'Website traffic',
    desc: 'Visitors, top pages, and sources from Google Analytics (GA4).',
    status: 'Connect GA4 (after domain is live)',
    note: 'Add your GA4 property + embed a Looker Studio report here.',
  },
  {
    title: 'Google Ads',
    desc: 'Spend, clicks, conversions, and cost-per-lead from your Ads account.',
    status: 'Connect Google Ads (after domain is live)',
    note: 'Conversion tracking gets wired into the site; performance shown via an embedded Looker Studio report.',
  },
  {
    title: 'Search rankings (SEO)',
    desc: 'Impressions, clicks, and queries from Google Search Console.',
    status: 'Connect Search Console (after domain is live)',
    note: 'Verify the property on launch, then embed the report here.',
  },
];
---

<AdminLayout title="Dashboard" authed={true} email={session.email}>
  <h1 class="dash-h1">Dashboard</h1>
  <p class="dash-sub">Welcome back. This is your marketing control panel for Caliber Scales.</p>

  <div class="dash-banner is-live">
    ✅ <strong>Live.</strong> The site is deployed and your enquiry form now saves
    leads here automatically. Traffic, Ads, and Search data light up once you
    connect the matching Google accounts (best done after the domain goes live).
  </div>

  <article class="dash-card dash-leads">
    <div class="dash-leads-head">
      <h2>Leads</h2>
      <div class="dash-leads-tools">
        <span class="dash-pill">{leadsError ? 'Store unavailable' : `${leads.length} captured`}</span>
        {!leadsError && leads.length > 0 && (
          <a class="dash-dl" href="/api/admin/leads-export">⬇ Download CSV</a>
        )}
      </div>
    </div>
    <p class="dash-card-desc">
      Enquiries from the website forms. Set a status, mark one invalid, or delete
      it — changes save instantly.
    </p>

    {
      leadsError ? (
        <p class="dash-card-note">Couldn’t load leads: {leadsError}</p>
      ) : leads.length === 0 ? (
        <p class="dash-card-note">
          No enquiries yet. New submissions from the website forms appear here
          automatically.
        </p>
      ) : (
        <div class="dash-table-wrap">
          <table class="dash-table">
            <thead>
              <tr>
                <th>Received</th>
                <th>Name</th>
                <th>Phone</th>
                <th>Company</th>
                <th>Requirement</th>
                <th>Source</th>
                <th>Status</th>
                <th aria-label="Delete" />
              </tr>
            </thead>
            <tbody>
              {leads.map((l) => (
                <tr class={l.status === 'invalid' ? 'is-invalid' : undefined}>
                  <td class="dash-nowrap">{fmtDate(l.receivedAt)}</td>
                  <td>{l.name}</td>
                  <td class="dash-nowrap">
                    <a href={`tel:${l.phone}`}>{l.phone}</a>
                  </td>
                  <td>{l.company || '—'}</td>
                  <td class="dash-req">{l.requirement}</td>
                  <td class="dash-src">{l.source || 'website'}</td>
                  <td>
                    <form method="POST" action="/api/admin/leads" class="dash-inline-form">
                      <input type="hidden" name="action" value="setStatus" />
                      <input type="hidden" name="key" value={l.key} />
                      <select
                        name="status"
                        class={`dash-status s-${l.status ?? 'new'}`}
                        data-autosubmit
                      >
                        {LEAD_STATUSES.map((s) => (
                          <option value={s} selected={(l.status ?? 'new') === s}>
                            {s}
                          </option>
                        ))}
                      </select>
                    </form>
                  </td>
                  <td>
                    <form method="POST" action="/api/admin/leads" class="dash-inline-form" data-confirm>
                      <input type="hidden" name="action" value="delete" />
                      <input type="hidden" name="key" value={l.key} />
                      <button type="submit" class="dash-del" title="Delete lead" aria-label="Delete lead">
                        ✕
                      </button>
                    </form>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )
    }
  </article>

  <section class="dash-grid">
    {
      cards.map((c) => (
        <article class="dash-card">
          <h2>{c.title}</h2>
          <p class="dash-card-desc">{c.desc}</p>
          <span class="dash-pill">{c.status}</span>
          <p class="dash-card-note">{c.note}</p>
        </article>
      ))
    }
  </section>

  <section class="dash-quick">
    <h2>Quick actions</h2>
    <div class="dash-actions">
      <a href="/keystatic" target="_blank" rel="noopener" class="dash-action">
        ✏️ Edit website content
        <span>Products, pages, blog, FAQs, settings</span>
      </a>
      <a href="/" target="_blank" rel="noopener" class="dash-action">
        🌐 View the website
        <span>Open the live site in a new tab</span>
      </a>
    </div>
  </section>

  <script is:inline>
    // Status dropdown saves on change; delete asks for confirmation first.
    document.querySelectorAll('select[data-autosubmit]').forEach(function (sel) {
      sel.addEventListener('change', function () {
        if (sel.form) sel.form.submit();
      });
    });
    document.querySelectorAll('form[data-confirm]').forEach(function (f) {
      f.addEventListener('submit', function (e) {
        if (!window.confirm('Delete this lead permanently? This cannot be undone.')) {
          e.preventDefault();
        }
      });
    });
  </script>

  <style>
    .dash-h1 { color: var(--navy); font-size: 1.6rem; margin: 0 0 0.25rem; }
    .dash-sub { color: var(--steel); margin: 0 0 1.25rem; }
    .dash-banner {
      background: #fff8e1;
      border: 1px dashed #d4a017;
      color: #7a5c00;
      padding: 0.8rem 1rem;
      border-radius: 8px;
      font-size: 0.9rem;
      margin-bottom: 1.5rem;
    }
    .dash-banner.is-live {
      background: rgba(29, 158, 117, 0.1);
      border: 1px solid rgba(29, 158, 117, 0.35);
      color: #0f6b4e;
    }
    .dash-leads {
      margin-bottom: 1.5rem;
    }
    .dash-leads-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.75rem;
    }
    .dash-leads-head h2 {
      font-size: 1.1rem;
      color: var(--navy);
      margin: 0;
    }
    .dash-table-wrap {
      overflow-x: auto;
      margin-top: 0.75rem;
    }
    .dash-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.85rem;
    }
    .dash-table th,
    .dash-table td {
      text-align: left;
      padding: 0.5rem 0.6rem;
      border-bottom: 1px solid var(--line);
      vertical-align: top;
    }
    .dash-table th {
      color: var(--steel);
      font-weight: 600;
      white-space: nowrap;
    }
    .dash-table td {
      color: #1a2433;
    }
    .dash-nowrap {
      white-space: nowrap;
    }
    .dash-req {
      min-width: 200px;
      max-width: 360px;
    }
    .dash-src {
      color: var(--steel);
      white-space: nowrap;
    }
    .dash-leads-tools {
      display: flex;
      align-items: center;
      gap: 0.6rem;
    }
    .dash-dl {
      font-size: 0.78rem;
      color: var(--accent);
      text-decoration: none;
      border: 1px solid var(--line);
      border-radius: 6px;
      padding: 0.25rem 0.6rem;
      white-space: nowrap;
    }
    .dash-dl:hover {
      border-color: var(--accent);
    }
    .dash-inline-form {
      margin: 0;
    }
    .dash-status {
      font-size: 0.78rem;
      padding: 0.22rem 0.35rem;
      border: 1px solid var(--line);
      border-radius: 6px;
      background: #fff;
      text-transform: capitalize;
      cursor: pointer;
    }
    .dash-status.s-won {
      color: #0f6b4e;
      border-color: rgba(29, 158, 117, 0.5);
      background: rgba(29, 158, 117, 0.08);
    }
    .dash-status.s-lost,
    .dash-status.s-invalid {
      color: #9b2226;
      border-color: rgba(190, 30, 45, 0.4);
      background: rgba(190, 30, 45, 0.06);
    }
    .dash-status.s-quoted,
    .dash-status.s-contacted {
      color: #7a5c00;
      border-color: rgba(212, 160, 23, 0.5);
      background: rgba(212, 160, 23, 0.08);
    }
    .dash-del {
      background: none;
      border: none;
      color: #b0392f;
      cursor: pointer;
      font-size: 0.9rem;
      line-height: 1;
      padding: 0.25rem 0.4rem;
      border-radius: 6px;
    }
    .dash-del:hover {
      background: rgba(190, 30, 45, 0.1);
    }
    tr.is-invalid td {
      opacity: 0.5;
    }
    .dash-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1rem;
      margin-bottom: 2rem;
    }
    .dash-card {
      background: #fff;
      border: 1px solid var(--line);
      border-radius: 10px;
      padding: 1.1rem 1.2rem;
    }
    .dash-card h2 { font-size: 1.1rem; color: var(--navy); margin: 0 0 0.35rem; }
    .dash-card-desc { color: #1a2433; font-size: 0.9rem; margin: 0 0 0.6rem; }
    .dash-pill {
      display: inline-block;
      background: var(--surface);
      color: var(--steel);
      font-size: 0.75rem;
      padding: 0.2rem 0.6rem;
      border-radius: 999px;
      border: 1px solid var(--line);
    }
    .dash-card-note { color: var(--steel); font-size: 0.82rem; margin: 0.6rem 0 0; }
    .dash-quick h2 { font-size: 1.1rem; color: var(--navy); }
    .dash-actions { display: grid; grid-template-columns: 1fr; gap: 0.75rem; }
    .dash-action {
      display: flex;
      flex-direction: column;
      gap: 0.2rem;
      background: #fff;
      border: 1px solid var(--line);
      border-radius: 10px;
      padding: 1rem 1.1rem;
      text-decoration: none;
      color: var(--navy);
      font-weight: 600;
    }
    .dash-action span { font-weight: 400; color: var(--steel); font-size: 0.85rem; }
    .dash-action:hover { border-color: var(--accent); }
    @media (min-width: 720px) {
      .dash-grid { grid-template-columns: repeat(2, 1fr); }
      .dash-actions { grid-template-columns: repeat(2, 1fr); }
    }
  </style>
</AdminLayout>
