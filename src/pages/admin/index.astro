---
/**
 * /admin — the dashboard. Protected: redirects to /admin/login without a valid
 * session. This is the SHELL — each section shows its status and gets wired to
 * live data after deploy (leads datastore, GA4, Google Ads, Search Console, or
 * embedded Looker Studio dashboards).
 */
export const prerender = false;

import AdminLayout from '@layouts/AdminLayout.astro';
import { SESSION_COOKIE, verifySessionToken } from '@lib/auth';
import { getStore } from '@netlify/blobs';

const session = verifySessionToken(Astro.cookies.get(SESSION_COOKIE)?.value);
if (!session) return Astro.redirect('/admin/login/');

interface Lead {
  name: string;
  company: string;
  phone: string;
  requirement: string;
  source?: string;
  receivedAt: string;
}

// Load recent leads from Netlify Blobs (newest first). Best-effort: if the store
// isn't reachable (e.g. local dev without the Netlify runtime) we show a note
// rather than break the dashboard.
let leads: Lead[] = [];
let leadsError: string | null = null;
try {
  const store = getStore('leads');
  const { blobs } = await store.list();
  const recent = blobs.sort((a, b) => (a.key < b.key ? 1 : -1)).slice(0, 50);
  leads = (
    await Promise.all(recent.map((b) => store.get(b.key, { type: 'json' }) as Promise<Lead>))
  ).filter(Boolean) as Lead[];
} catch (err) {
  leadsError = err instanceof Error ? err.message : 'Lead store unavailable.';
}

const fmtDate = (iso: string) => {
  try {
    return new Date(iso).toLocaleString('en-IN', {
      timeZone: 'Asia/Kolkata',
      dateStyle: 'medium',
      timeStyle: 'short',
    });
  } catch {
    return iso;
  }
};

const cards = [
  {
    title: 'Website traffic',
    desc: 'Visitors, top pages, and sources from Google Analytics (GA4).',
    status: 'Connect GA4 (after domain is live)',
    note: 'Add your GA4 property + embed a Looker Studio report here.',
  },
  {
    title: 'Google Ads',
    desc: 'Spend, clicks, conversions, and cost-per-lead from your Ads account.',
    status: 'Connect Google Ads (after domain is live)',
    note: 'Conversion tracking gets wired into the site; performance shown via an embedded Looker Studio report.',
  },
  {
    title: 'Search rankings (SEO)',
    desc: 'Impressions, clicks, and queries from Google Search Console.',
    status: 'Connect Search Console (after domain is live)',
    note: 'Verify the property on launch, then embed the report here.',
  },
];
---

<AdminLayout title="Dashboard" authed={true} email={session.email}>
  <h1 class="dash-h1">Dashboard</h1>
  <p class="dash-sub">Welcome back. This is your marketing control panel for Caliber Scales.</p>

  <div class="dash-banner is-live">
    ✅ <strong>Live.</strong> The site is deployed and your enquiry form now saves
    leads here automatically. Traffic, Ads, and Search data light up once you
    connect the matching Google accounts (best done after the domain goes live).
  </div>

  <article class="dash-card dash-leads">
    <div class="dash-leads-head">
      <h2>Leads</h2>
      <span class="dash-pill">{leadsError ? 'Store unavailable' : `${leads.length} captured`}</span>
    </div>
    <p class="dash-card-desc">Enquiries submitted through the website forms.</p>

    {
      leadsError ? (
        <p class="dash-card-note">Couldn’t load leads: {leadsError}</p>
      ) : leads.length === 0 ? (
        <p class="dash-card-note">
          No enquiries yet. New submissions from the website forms appear here
          automatically.
        </p>
      ) : (
        <div class="dash-table-wrap">
          <table class="dash-table">
            <thead>
              <tr>
                <th>Received</th>
                <th>Name</th>
                <th>Phone</th>
                <th>Company</th>
                <th>Requirement</th>
                <th>Source</th>
              </tr>
            </thead>
            <tbody>
              {leads.map((l) => (
                <tr>
                  <td class="dash-nowrap">{fmtDate(l.receivedAt)}</td>
                  <td>{l.name}</td>
                  <td class="dash-nowrap">
                    <a href={`tel:${l.phone}`}>{l.phone}</a>
                  </td>
                  <td>{l.company || '—'}</td>
                  <td class="dash-req">{l.requirement}</td>
                  <td class="dash-src">{l.source || 'website'}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )
    }
  </article>

  <section class="dash-grid">
    {
      cards.map((c) => (
        <article class="dash-card">
          <h2>{c.title}</h2>
          <p class="dash-card-desc">{c.desc}</p>
          <span class="dash-pill">{c.status}</span>
          <p class="dash-card-note">{c.note}</p>
        </article>
      ))
    }
  </section>

  <section class="dash-quick">
    <h2>Quick actions</h2>
    <div class="dash-actions">
      <a href="/keystatic" target="_blank" rel="noopener" class="dash-action">
        ✏️ Edit website content
        <span>Products, pages, blog, FAQs, settings</span>
      </a>
      <a href="/" target="_blank" rel="noopener" class="dash-action">
        🌐 View the website
        <span>Open the live site in a new tab</span>
      </a>
    </div>
  </section>

  <style>
    .dash-h1 { color: var(--navy); font-size: 1.6rem; margin: 0 0 0.25rem; }
    .dash-sub { color: var(--steel); margin: 0 0 1.25rem; }
    .dash-banner {
      background: #fff8e1;
      border: 1px dashed #d4a017;
      color: #7a5c00;
      padding: 0.8rem 1rem;
      border-radius: 8px;
      font-size: 0.9rem;
      margin-bottom: 1.5rem;
    }
    .dash-banner.is-live {
      background: rgba(29, 158, 117, 0.1);
      border: 1px solid rgba(29, 158, 117, 0.35);
      color: #0f6b4e;
    }
    .dash-leads {
      margin-bottom: 1.5rem;
    }
    .dash-leads-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.75rem;
    }
    .dash-leads-head h2 {
      font-size: 1.1rem;
      color: var(--navy);
      margin: 0;
    }
    .dash-table-wrap {
      overflow-x: auto;
      margin-top: 0.75rem;
    }
    .dash-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.85rem;
    }
    .dash-table th,
    .dash-table td {
      text-align: left;
      padding: 0.5rem 0.6rem;
      border-bottom: 1px solid var(--line);
      vertical-align: top;
    }
    .dash-table th {
      color: var(--steel);
      font-weight: 600;
      white-space: nowrap;
    }
    .dash-table td {
      color: #1a2433;
    }
    .dash-nowrap {
      white-space: nowrap;
    }
    .dash-req {
      min-width: 200px;
      max-width: 360px;
    }
    .dash-src {
      color: var(--steel);
      white-space: nowrap;
    }
    .dash-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1rem;
      margin-bottom: 2rem;
    }
    .dash-card {
      background: #fff;
      border: 1px solid var(--line);
      border-radius: 10px;
      padding: 1.1rem 1.2rem;
    }
    .dash-card h2 { font-size: 1.1rem; color: var(--navy); margin: 0 0 0.35rem; }
    .dash-card-desc { color: #1a2433; font-size: 0.9rem; margin: 0 0 0.6rem; }
    .dash-pill {
      display: inline-block;
      background: var(--surface);
      color: var(--steel);
      font-size: 0.75rem;
      padding: 0.2rem 0.6rem;
      border-radius: 999px;
      border: 1px solid var(--line);
    }
    .dash-card-note { color: var(--steel); font-size: 0.82rem; margin: 0.6rem 0 0; }
    .dash-quick h2 { font-size: 1.1rem; color: var(--navy); }
    .dash-actions { display: grid; grid-template-columns: 1fr; gap: 0.75rem; }
    .dash-action {
      display: flex;
      flex-direction: column;
      gap: 0.2rem;
      background: #fff;
      border: 1px solid var(--line);
      border-radius: 10px;
      padding: 1rem 1.1rem;
      text-decoration: none;
      color: var(--navy);
      font-weight: 600;
    }
    .dash-action span { font-weight: 400; color: var(--steel); font-size: 0.85rem; }
    .dash-action:hover { border-color: var(--accent); }
    @media (min-width: 720px) {
      .dash-grid { grid-template-columns: repeat(2, 1fr); }
      .dash-actions { grid-template-columns: repeat(2, 1fr); }
    }
  </style>
</AdminLayout>
