---
/**
 * /admin/login — email/password login for the custom admin. Handles both GET
 * (show form) and POST (verify → set session cookie → redirect to /admin).
 */
export const prerender = false;

import AdminLayout from '@layouts/AdminLayout.astro';
import {
  SESSION_COOKIE,
  checkCredentials,
  createSessionToken,
  verifySessionToken,
  sessionCookieOptions,
  isConfigured,
} from '@lib/auth';

const { cookies, request, redirect } = Astro;

// Already logged in? Go to the dashboard.
if (request.method === 'GET') {
  const existing = verifySessionToken(cookies.get(SESSION_COOKIE)?.value);
  if (existing) return redirect('/admin/');
}

let error = '';
if (request.method === 'POST') {
  const form = await request.formData();
  const email = String(form.get('email') ?? '');
  const password = String(form.get('password') ?? '');
  if (checkCredentials(email, password)) {
    cookies.set(SESSION_COOKIE, createSessionToken(email.trim().toLowerCase()), sessionCookieOptions);
    return redirect('/admin/');
  }
  error = 'Invalid email or password.';
}

const configured = isConfigured();
---

<AdminLayout title="Sign in">
  <div class="login-wrap">
    <form method="POST" class="login-card">
      <img src="/images/brand/caliber-logo.png" alt="Caliber Scales" height="34" class="login-logo" />
      <h1>Admin sign in</h1>

      {!configured && (
        <p class="login-warn">
          ⚠️ Admin credentials aren't configured yet. Set <code>AUTH_SECRET</code>,
          <code>ADMIN_EMAIL</code> and <code>ADMIN_PASSWORD_HASH</code> in your
          environment (see README).
        </p>
      )}

      {error && <p class="login-error">{error}</p>}

      <label for="email">Email</label>
      <input id="email" name="email" type="email" autocomplete="username" required />

      <label for="password">Password</label>
      <input id="password" name="password" type="password" autocomplete="current-password" required />

      <button type="submit" class="login-btn">Sign in</button>
    </form>
  </div>

  <style>
    .login-wrap { min-height: 70vh; display: grid; place-items: center; }
    .login-card {
      width: 100%;
      max-width: 380px;
      background: #fff;
      border: 1px solid var(--line);
      border-radius: 10px;
      padding: 1.75rem;
      display: grid;
      gap: 0.5rem;
      box-shadow: 0 18px 40px -28px rgba(12, 45, 82, 0.45);
    }
    .login-logo { justify-self: start; margin-bottom: 0.5rem; }
    .login-card h1 { font-size: 1.3rem; margin: 0 0 0.75rem; color: var(--navy); }
    .login-card label { font-size: 0.85rem; font-weight: 600; color: var(--navy); margin-top: 0.5rem; }
    .login-card input {
      padding: 0.6rem 0.7rem;
      border: 1px solid #c9d2dc;
      border-radius: 6px;
      font: inherit;
    }
    .login-card input:focus { outline: none; border-color: var(--accent); box-shadow: 0 0 0 3px rgba(30,115,190,0.18); }
    .login-btn {
      margin-top: 1rem;
      padding: 0.7rem 1rem;
      background: var(--accent);
      color: #fff;
      border: 0;
      border-radius: 6px;
      font-weight: 600;
      cursor: pointer;
    }
    .login-btn:hover { background: var(--navy-600); }
    .login-error { background: rgba(190,30,45,0.1); color: #9b2226; padding: 0.6rem 0.75rem; border-radius: 6px; margin: 0; font-size: 0.9rem; }
    .login-warn { background: #fff8e1; color: #7a5c00; padding: 0.6rem 0.75rem; border-radius: 6px; margin: 0 0 0.5rem; font-size: 0.82rem; }
    code { background: var(--surface); padding: 0 3px; border-radius: 3px; }
  </style>
</AdminLayout>
