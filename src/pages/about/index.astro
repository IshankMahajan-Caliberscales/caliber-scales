---
/**
 * About — company overview (spec A4/B4). Uses only confirmed facts (founded
 * 2001, ISO 9001:2015, 5,000+ installations, 25+ states & UTs, Delhi HQ).
 * Detailed history/profile prose is flagged as pending real client copy.
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import Section from '@components/ui/Section.astro';
import Hero from '@components/blocks/Hero.astro';
import TrustBar from '@components/blocks/TrustBar.astro';
import FeatureList from '@components/blocks/FeatureList.astro';
import ProductGrid from '@components/blocks/ProductGrid.astro';
import { STATS, CONTACT } from '@lib/site';

const subpages = [
  { title: 'Certifications', href: '/about/certifications/', blurb: 'ISO 9001:2015 and our quality commitments.' },
  { title: 'Infrastructure', href: '/about/infrastructure/', blurb: 'Our manufacturing unit and capabilities.' },
  { title: 'Team', href: '/about/team/', blurb: 'The people behind Caliber Scales.' },
];
---

<BaseLayout
  title="About Caliber Scales"
  description={`Caliber Scales India is an ISO 9001:2015 certified manufacturer of industrial weighing solutions, established in ${STATS.foundedYear}, with ${STATS.installations} installations across ${STATS.statesCovered} states and Union Territories.`}
  crumbs={[{ name: 'About', href: '/about/' }]}
>
  <Hero
    eyebrow="About us"
    title="A weighing manufacturer, trusted across India"
    lede={`Established in ${STATS.foundedYear}, Caliber Scales India designs, manufactures, installs, and services industrial weighing equipment — from weighbridges to precision balances.`}
    showCtas={false}
  />

  <TrustBar />

  <Section title="Who we are">
    <div class="prose">
      <p>
        Founded in <strong>{STATS.foundedYear}</strong>, Caliber Scales India Pvt. Ltd. is an
        <strong>{STATS.certification} certified weighbridge manufacturer in India</strong> and a
        leading producer of electronic weighing machines, industrial weighing
        systems, and customised weighing solutions.
      </p>
      <p>
        We design, manufacture, install, and service a complete range of
        industrial weighing equipment, including heavy-duty weighbridges and
        high-precision electronic weighing scales. As a manufacturer, we maintain
        full control over engineering, component quality, calibration standards,
        and system performance.
      </p>
      <p>
        Our focus is simple: <strong>accurate weighing, durable engineering, and
        long-term reliability</strong> for industrial operations across India.
      </p>
      <p>
        We are recognised as a reliable supplier of weighbridges in India and
        industrial weighing solutions for critical sectors such as construction,
        logistics, cement, mining, steel, agriculture, and pharmaceuticals.
      </p>
      <p>Our core product range includes:</p>
      <ul class="range">
        <li>Truck Weighbridges (Pit Type, Surface Mounted Weighbridges)</li>
        <li>Mobile Weighbridges and Portable Weighing Systems</li>
        <li>Electronic Platform Scales &amp; Heavy-Duty Floor Scales</li>
        <li>Laboratory and Precision Balances</li>
        <li>Conveyor Weighing Systems (Dynamic &amp; Static)</li>
        <li>Tank, Silo, Hopper, and Vessel Weighing Systems</li>
        <li>Checkweighers and Automated Weighing Systems</li>
        <li>Fully Customised Industrial Weighing Solutions</li>
      </ul>
      <p>
        Each system is engineered for <strong>high accuracy, rugged industrial use,
        and long service life</strong>, ensuring dependable performance in demanding
        environments.
      </p>
    </div>
  </Section>

  <Section surface title="Our mission">
    <p class="prose">
      To deliver high-precision, durable, and technologically advanced weighing
      systems in India that improve operational efficiency, ensure compliance, and
      support industrial growth.
    </p>
  </Section>

  <Section title="Why work with us">
    <FeatureList />
  </Section>

  <Section title="Explore">
    <ProductGrid items={subpages} />
  </Section>

  <Section surface title="Visit or contact us">
    <address class="contact-block">
      {CONTACT.address.streetAddress},<br />
      {CONTACT.address.addressLocality} {CONTACT.address.postalCode}, India<br />
      <a href={`tel:${CONTACT.phone}`}>{CONTACT.phoneDisplay}</a> ·
      <a href={`mailto:${CONTACT.email}`}>{CONTACT.email}</a>
    </address>
  </Section>
</BaseLayout>

<style>
  .prose {
    max-width: 65ch;
  }
  .prose p {
    margin: 0 0 1rem;
    line-height: 1.7;
  }
  .range {
    margin: 0 0 1rem;
    padding-left: 1.25rem;
    line-height: 1.8;
  }
  .placeholder-note {
    padding: 0.75rem 1rem;
    background: var(--color-surface);
    border: 1px dashed var(--color-steel);
    border-radius: var(--radius-card);
    font-size: 0.88rem;
    color: var(--color-steel);
  }
  .contact-block {
    font-style: normal;
    line-height: 1.9;
  }
</style>
