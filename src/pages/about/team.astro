---
/**
 * About → Team. Placeholder structure. Real names, roles, and photos are added
 * only from client-supplied content — no team members are invented.
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import Section from '@components/ui/Section.astro';
import Hero from '@components/blocks/Hero.astro';
---

<BaseLayout
  title="Our Team"
  description="The people behind Caliber Scales India."
  crumbs={[
    { name: 'About', href: '/about/' },
    { name: 'Team', href: '/about/team/' },
  ]}
>
  <Hero
    eyebrow="About us"
    title="Our team"
    lede="Engineers, technicians, and support staff who design, build, and service your weighing equipment."
    showCtas={false}
  />

  <Section>
    <p class="placeholder-note">
      🚧 Team profiles (names, roles, and photos) will be added here from
      client-supplied content. None are invented.
    </p>
  </Section>
</BaseLayout>

<style>
  .placeholder-note {
    max-width: 65ch;
    padding: 0.75rem 1rem;
    background: var(--color-surface);
    border: 1px dashed var(--color-steel);
    border-radius: var(--radius-card);
    font-size: 0.88rem;
    color: var(--color-steel);
  }
</style>
