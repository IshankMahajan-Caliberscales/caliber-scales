---
/**
 * Buying guides listing (type === 'buying-guide'). Drafts shown only in dev.
 */
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import Section from '@components/ui/Section.astro';
import Hero from '@components/blocks/Hero.astro';
import ArticleCard from '@components/blocks/ArticleCard.astro';
import { formatDate } from '@lib/format';

const all = await getCollection('blog', ({ data }) => data.type === 'buying-guide');
const visible = (import.meta.env.PROD ? all.filter((p) => !p.data.draft) : all).sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()
);
---

<BaseLayout
  title="Buying Guides"
  metaTitle="Weighing Equipment Buying Guides | Caliber Scales"
  description="Practical buying guides to help you choose the right weighbridge, scale, or weighing system for your needs."
  crumbs={[
    { name: 'Resources', href: '/resources/' },
    { name: 'Buying guides', href: '/resources/buying-guides/' },
  ]}
>
  <Hero eyebrow="Resources" title="Buying guides" lede="Choose the right weighing equipment with confidence." showCtas={false} />

  <Section>
    {
      visible.length > 0 ? (
        <div class="grid">
          {visible.map((p) => (
            <ArticleCard
              title={p.data.title}
              href={`/resources/buying-guides/${p.id}/`}
              excerpt={p.data.excerpt}
              date={formatDate(p.data.publishDate)}
              image={p.data.heroImage}
              tag="Buying guide"
              draft={p.data.draft}
            />
          ))}
        </div>
      ) : (
        <p class="empty">No buying guides published yet — check back soon.</p>
      )
    }
  </Section>
</BaseLayout>

<style>
  .grid { display: grid; grid-template-columns: 1fr; gap: 1.5rem; }
  .empty { color: var(--color-steel); }
  @media (min-width: 640px) { .grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 980px) { .grid { grid-template-columns: repeat(3, 1fr); } }
</style>
