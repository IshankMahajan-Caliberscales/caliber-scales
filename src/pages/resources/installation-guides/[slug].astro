---
/**
 * /resources/installation-guides/<slug>/ — guide detail (installation-guide).
 */
import { getCollection, type CollectionEntry } from 'astro:content';
import ArticleLayout from '@layouts/ArticleLayout.astro';

export async function getStaticPaths() {
  const guides = await getCollection('blog', ({ data }) => data.type === 'installation-guide');
  return guides.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props as { entry: CollectionEntry<'blog'> };
---

<ArticleLayout entry={entry} />
