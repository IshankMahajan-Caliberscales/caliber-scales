---
/**
 * /resources/case-studies/<slug>/ — case study detail.
 */
import { getCollection, type CollectionEntry } from 'astro:content';
import CaseStudyLayout from '@layouts/CaseStudyLayout.astro';

export async function getStaticPaths() {
  const studies = await getCollection('caseStudies');
  return studies.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props as { entry: CollectionEntry<'caseStudies'> };
---

<CaseStudyLayout entry={entry} />
