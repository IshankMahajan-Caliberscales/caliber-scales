---
/**
 * Resources hub (spec B4/B5) — routes to blog, guides, case studies, and FAQs.
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import Section from '@components/ui/Section.astro';
import Hero from '@components/blocks/Hero.astro';
import ProductGrid from '@components/blocks/ProductGrid.astro';
import type { CategoryCard } from '@lib/catalog';

const cards: CategoryCard[] = [
  { title: 'Blog', href: '/resources/blog/', blurb: 'Expert articles on industrial weighing, from a manufacturer.' },
  { title: 'FAQs', href: '/resources/faqs/', blurb: 'Answers to common weighing questions.' },
];
---

<BaseLayout
  title="Resources"
  metaTitle="Weighing Resources & FAQs | Caliber Scales"
  description="Articles and FAQs on industrial weighing — from a manufacturer with decades of experience."
  crumbs={[{ name: 'Resources', href: '/resources/' }]}
>
  <Hero
    eyebrow="Resources"
    title="Weighing knowledge, from the manufacturer"
    lede="Guides, articles, case studies, and FAQs to help you choose, install, and maintain the right weighing equipment."
  />

  <Section title="Explore resources">
    <ProductGrid items={cards} />
  </Section>
</BaseLayout>
