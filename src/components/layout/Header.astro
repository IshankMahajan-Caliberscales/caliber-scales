---
/**
 * Site header: logo/wordmark, primary Nav, and a "Request quote" CTA.
 * Mobile menu toggle + submenu accordions handled by the inline script below
 * (Astro island-free; ~30 lines of vanilla JS for top CWV per B7).
 */
import Nav from './Nav.astro';
import { SITE, telLink, CONTACT } from '@lib/site';
---

<header class="site-header">
  <div class="container-page header-inner">
    <a href="/" class="brand" aria-label={`${SITE.name} — home`}>
      <img
        src="/images/brand/caliber-logo.png"
        alt={SITE.name}
        class="brand-logo"
        width="76"
        height="38"
        fetchpriority="high"
      />
    </a>

    <button
      type="button"
      class="menu-toggle"
      id="menu-toggle"
      aria-expanded="false"
      aria-controls="primary-nav"
    >
      <span class="sr-only">Menu</span>
      <span class="menu-bars" aria-hidden="true"></span>
    </button>

    <div class="nav-wrap" id="nav-wrap">
      <Nav />
      <div class="header-cta">
        <a href={telLink()} class="btn btn-secondary call-link">
          <span aria-hidden="true">📞</span>
          <span>{CONTACT.phoneDisplay}</span>
        </a>
        <a href="/contact/" class="btn btn-primary">Request quote</a>
      </div>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 60;
    background: #fff;
    border-bottom: 1px solid var(--color-surface);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    min-height: 64px;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
  }
  .brand-logo {
    height: 38px;
    width: auto;
    display: block;
  }
  @media (min-width: 900px) {
    .brand-logo {
      height: 42px;
    }
  }
  .menu-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    background: none;
    border: 1px solid var(--color-surface);
    border-radius: 6px;
    cursor: pointer;
  }
  /* While the mobile menu is open, drop the logo and keep the close button
     anchored to the right (the menu panel wraps onto its own line below). */
  .site-header.menu-open .brand {
    display: none;
  }
  .site-header.menu-open .menu-toggle {
    margin-left: auto;
  }
  .menu-bars,
  .menu-bars::before,
  .menu-bars::after {
    content: '';
    display: block;
    width: 20px;
    height: 2px;
    background: var(--color-navy);
    position: relative;
    transition: transform 0.2s ease, background-color 0.2s ease, top 0.2s ease;
  }
  .menu-bars::before {
    position: absolute;
    top: -6px;
  }
  .menu-bars::after {
    position: absolute;
    top: 6px;
  }
  /* Morph the bars into an X while the menu is open. */
  .menu-toggle[aria-expanded='true'] .menu-bars {
    background: transparent;
  }
  .menu-toggle[aria-expanded='true'] .menu-bars::before {
    top: 0;
    transform: rotate(45deg);
  }
  .menu-toggle[aria-expanded='true'] .menu-bars::after {
    top: 0;
    transform: rotate(-45deg);
  }
  .nav-wrap {
    display: none;
    width: 100%;
  }
  .nav-wrap.open {
    display: block;
    margin-top: 0.5rem;
    padding-bottom: 0.75rem;
    border-top: 1px solid var(--color-surface);
    animation: navReveal 0.18s ease-out;
  }
  @keyframes navReveal {
    from {
      opacity: 0;
      transform: translateY(-6px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .header-cta {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    margin-top: 0.85rem;
    padding-top: 0.85rem;
    border-top: 1px solid var(--color-surface);
  }
  .header-cta .btn {
    width: 100%;
  }
  .call-link {
    font-size: 0.95rem;
  }

  @media (min-width: 900px) {
    .menu-toggle {
      display: none;
    }
    /* The logo always shows on desktop, regardless of any leftover open state. */
    .site-header.menu-open .brand {
      display: inline-flex;
    }
    .nav-wrap {
      display: flex !important;
      align-items: center;
      justify-content: flex-end;
      gap: 1.5rem;
      width: auto;
      flex: 1;
      margin-top: 0;
      padding-bottom: 0;
      border-top: 0;
    }
    .header-cta {
      flex-direction: row;
      margin-top: 0;
      padding-top: 0;
      border-top: 0;
      align-items: center;
    }
    .header-cta .btn {
      width: auto;
    }
  }
</style>

<!--
  Inlined (is:inline) on purpose: keeps this tiny menu logic out of the JS
  bundler. @astrojs/react's dev Fast-Refresh wrapper + rolldown-vite throws
  "Missing field moduleType" when transforming hoisted client scripts, which
  500s them and silently breaks the mobile menu. Plain inline JS sidesteps it.
-->
<script is:inline>
  (function () {
    // Mobile menu toggle
    var toggle = document.getElementById('menu-toggle');
    var navWrap = document.getElementById('nav-wrap');
    var header = document.querySelector('.site-header');
    if (toggle && navWrap) {
      toggle.addEventListener('click', function () {
        var open = navWrap.classList.toggle('open');
        toggle.setAttribute('aria-expanded', String(open));
        // Hide the logo while the menu panel is open (mobile only — see CSS).
        if (header) header.classList.toggle('menu-open', open);
      });
    }

    // Mobile submenu accordions
    document.querySelectorAll('.nav-submenu-toggle').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var li = btn.closest('.nav-item');
        var open = li ? li.classList.toggle('open') : false;
        btn.setAttribute('aria-expanded', String(open));
      });
    });
  })();
</script>
