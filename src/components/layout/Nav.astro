---
/**
 * Primary navigation. Desktop: horizontal with hover/focus dropdowns.
 * Mobile: a toggle button reveals a stacked menu (progressive enhancement —
 * a tiny inline script in Header handles the toggle and keyboard support).
 * Keyboard-navigable per B11.
 */
import { NAV } from '@lib/site';
import { getProductCards } from '@lib/products';

const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);

// The Products submenu is built live from the CMS so new products appear
// automatically; the rest of the nav stays as configured in site.ts.
const productCards = await getProductCards();
const navItems = NAV.map((item) =>
  item.href === '/products/'
    ? { ...item, children: productCards.map((p) => ({ label: p.title, href: p.href })) }
    : item
);
---

<ul class="nav-list" id="primary-nav">
  {
    navItems.map((item) => (
      <li class={`nav-item${item.children ? ' has-children' : ''}`}>
        <a
          href={item.href}
          class="nav-link"
          aria-current={isActive(item.href) ? 'page' : undefined}
        >
          {item.label}
        </a>
        {item.children && (
          <>
            <button
              type="button"
              class="nav-submenu-toggle"
              aria-expanded="false"
              aria-label={`Toggle ${item.label} submenu`}
            >
              <svg class="chev" width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M5 9l7 7 7-7" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </button>
            <ul class="nav-submenu">
              {item.children.map((child) => (
                <li>
                  <a
                    href={child.href}
                    class="nav-sublink"
                    aria-current={isActive(child.href) ? 'page' : undefined}
                  >
                    {child.label}
                  </a>
                </li>
              ))}
            </ul>
          </>
        )}
      </li>
    ))
  }
</ul>

<style>
  /* Mobile-first: a clean stacked menu inside the toggled panel. */
  .nav-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .nav-item {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    border-top: 1px solid var(--color-surface);
  }
  .nav-list > .nav-item:first-child {
    border-top: 0;
  }
  .nav-link {
    flex: 1 1 auto;
    display: block;
    padding: 0.85rem 0.5rem;
    color: var(--color-navy);
    text-decoration: none;
    font-weight: 500;
    border-radius: var(--radius-btn);
  }
  .nav-link:hover,
  .nav-link[aria-current='page'] {
    color: var(--color-navy-600);
  }
  .nav-submenu-toggle {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    background: none;
    border: 0;
    color: var(--color-steel);
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
  }
  .nav-submenu-toggle .chev {
    transition: transform 0.25s ease, color 0.2s ease;
  }
  .nav-item.open > .nav-submenu-toggle {
    color: var(--color-navy-600);
  }
  .nav-item.open > .nav-submenu-toggle .chev {
    transform: rotate(180deg);
  }
  /* Tie the chevron's colour to the parent label on open. */
  .nav-item.open > .nav-link {
    color: var(--color-navy-600);
  }
  .nav-submenu {
    flex-basis: 100%;
    width: 100%;
    list-style: none;
    margin: 0 0 0.5rem 0.5rem;
    padding: 0.1rem 0 0.2rem 0.85rem;
    border-left: 2px solid #d8dfe6;
    display: none;
  }
  .nav-item.open > .nav-submenu {
    display: block;
  }
  .nav-sublink {
    display: block;
    padding: 0.55rem 0.5rem;
    color: var(--color-steel);
    text-decoration: none;
    font-size: 0.95rem;
    border-radius: var(--radius-btn);
  }
  .nav-sublink:hover,
  .nav-sublink[aria-current='page'] {
    color: var(--color-navy-600);
    background-color: var(--color-surface);
  }

  /* Desktop: horizontal bar with hover/focus dropdown panels. */
  @media (min-width: 900px) {
    .nav-list {
      flex-direction: row;
      align-items: center;
      gap: 0.25rem;
    }
    .nav-item {
      display: block;
      position: relative;
      border-top: 0;
    }
    .nav-link {
      flex: none;
      padding: 0.6rem 0.75rem;
    }
    .nav-link:hover,
    .nav-link[aria-current='page'] {
      background-color: var(--color-surface);
    }
    .nav-submenu-toggle {
      display: none;
    }
    .nav-submenu {
      position: absolute;
      top: 100%;
      left: 0;
      min-width: 16rem;
      margin: 0;
      padding: 0.5rem;
      background: #fff;
      border: 1px solid var(--color-surface);
      border-radius: var(--radius-card);
      box-shadow: 0 12px 30px -12px rgba(12, 45, 82, 0.25);
      z-index: 50;
    }
    .nav-item.has-children:hover > .nav-submenu,
    .nav-item.has-children:focus-within > .nav-submenu {
      display: block;
    }
    .nav-sublink {
      padding: 0.5rem 0.6rem;
      font-size: 1rem;
    }
  }
</style>
