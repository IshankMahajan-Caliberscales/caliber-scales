---
/**
 * JsonLd — renders one or more schema objects as <script type="application/ld+json">.
 * Pass a single object or an array (spec B6). Builders live in @lib/schema.
 */
interface Props {
  schema: Record<string, unknown> | Record<string, unknown>[];
}

const { schema } = Astro.props;
const items = Array.isArray(schema) ? schema : [schema];
---

{
  items.map((item) => (
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(item)}
    />
  ))
}
