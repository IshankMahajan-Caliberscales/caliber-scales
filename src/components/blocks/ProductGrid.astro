---
/**
 * ProductGrid — responsive grid of linked product-category cards (spec B5).
 * Pass any CategoryCard[] (product categories or weighbridge types).
 */
import type { CategoryCard } from '@lib/catalog';

interface Props {
  items: CategoryCard[];
}

const { items } = Astro.props;
---

<ul class="product-grid">
  {
    items.map((item) => (
      <li>
        <a href={item.href} class:list={['product-card', { 'has-media': !!item.image }]}>
          {item.image && (
            <span class="product-media">
              <img src={item.image} alt={item.imageAlt ?? ''} loading="lazy" decoding="async" width="400" height="300" />
            </span>
          )}
          <span class="product-body">
            <span class="product-title">
              {item.title}
              <span class="arrow" aria-hidden="true">→</span>
            </span>
            <span class="product-blurb">{item.blurb}</span>
          </span>
        </a>
      </li>
    ))
  }
</ul>

<style>
  .product-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  .product-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 1.25rem;
    background: #fff;
    border: 1px solid #e4e9ee;
    border-radius: var(--radius-card);
    text-decoration: none;
    overflow: hidden;
    transition: border-color 0.15s ease, box-shadow 0.15s ease, transform 0.15s ease;
  }
  /* When a photo is present, let it run full-bleed and move padding to the body. */
  .product-card.has-media {
    padding: 0;
  }
  .product-card:hover {
    border-color: var(--color-accent);
    box-shadow: 0 12px 28px -16px rgba(12, 45, 82, 0.4);
    transform: translateY(-2px);
  }
  .product-media {
    display: block;
    /* Responsive frame: the image scales to fit it on any screen width. */
    aspect-ratio: 3 / 2;
    background: #fff;
    border-bottom: 1px solid #eef1f4;
    overflow: hidden;
  }
  .product-media img {
    width: 100%;
    height: 100%;
    /* contain (not cover) so the whole product is always shown — never cropped,
       and never upscaled past its size — across phones, tablets, and desktop. */
    object-fit: contain;
    box-sizing: border-box;
    padding: 1rem;
    display: block;
    transition: transform 0.3s ease;
  }
  .product-card:hover .product-media img {
    transform: scale(1.03);
  }
  /* Shorter image frame on small single-column screens so cards aren't too tall. */
  @media (max-width: 599px) {
    .product-media {
      aspect-ratio: 16 / 9;
    }
  }
  .product-body {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }
  .product-card.has-media .product-body {
    padding: 1.1rem 1.2rem 1.3rem;
  }
  .product-title {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    font-weight: 500;
    font-size: 1.1rem;
    color: var(--color-navy);
  }
  .arrow {
    color: var(--color-accent);
    transition: transform 0.15s ease;
  }
  .product-card:hover .arrow {
    transform: translateX(3px);
  }
  .product-blurb {
    color: var(--color-steel);
    font-size: 0.95rem;
    line-height: 1.5;
  }
  @media (min-width: 600px) {
    .product-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 960px) {
    .product-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
