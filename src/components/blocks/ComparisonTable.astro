---
/**
 * ComparisonTable — side-by-side comparison of options (spec B5, e.g. pitless
 * vs pit-mounted). `columns` are the option names; each row has a feature label
 * and one value per column.
 */
import type { Comparison } from '@lib/comparisons';

interface Props {
  data: Comparison;
}

const { data } = Astro.props;
---

<div class="cmp">
  {data.intro && <p class="cmp-intro">{data.intro}</p>}
  <div class="cmp-wrap">
    <table class="cmp-table">
      <thead>
        <tr>
          <th scope="col"></th>
          {data.columns.map((c) => <th scope="col">{c}</th>)}
        </tr>
      </thead>
      <tbody>
        {
          data.rows.map((row) => (
            <tr>
              <th scope="row">{row.feature}</th>
              {row.values.map((v) => <td>{v}</td>)}
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>
</div>

<style>
  .cmp-intro {
    margin: 0 0 1rem;
    color: var(--color-steel);
    max-width: 60ch;
  }
  .cmp-wrap {
    overflow-x: auto;
    border: 1px solid #e4e9ee;
    border-radius: var(--radius-card);
  }
  .cmp-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.92rem;
    min-width: 480px;
  }
  .cmp-table th,
  .cmp-table td {
    text-align: left;
    padding: 0.7rem 0.9rem;
    vertical-align: top;
    border-top: 1px solid #e4e9ee;
  }
  .cmp-table thead th {
    border-top: 0;
    background: var(--color-navy);
    color: #fff;
    font-weight: 500;
  }
  .cmp-table tbody th {
    color: var(--color-steel);
    font-weight: 500;
    background: var(--color-surface);
    width: 28%;
  }
  .cmp-table td {
    color: var(--color-navy);
  }
</style>
