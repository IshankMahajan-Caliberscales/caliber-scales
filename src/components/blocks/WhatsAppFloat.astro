---
/** Floating WhatsApp button, fixed bottom-right on all pages (spec A8/B5). */
import { whatsappLink } from '@lib/site';
---

<a
  href={whatsappLink()}
  class="whatsapp-float"
  rel="noopener"
  aria-label="Chat with us on WhatsApp"
  data-cta="whatsapp"
>
  <svg viewBox="0 0 32 32" width="28" height="28" aria-hidden="true" fill="currentColor">
    <path
      d="M16 3C9.4 3 4 8.4 4 15c0 2.1.6 4.2 1.6 6L4 29l8.2-1.6c1.7.9 3.7 1.4 5.8 1.4 6.6 0 12-5.4 12-12S22.6 3 16 3zm0 21.8c-1.8 0-3.5-.5-5-1.4l-.4-.2-4.9 1 1-4.8-.3-.4A9.8 9.8 0 0 1 6.2 15C6.2 9.6 10.6 5.2 16 5.2S25.8 9.6 25.8 15 21.4 24.8 16 24.8zm5.6-7.3c-.3-.2-1.8-.9-2.1-1-.3-.1-.5-.2-.7.2-.2.3-.8 1-.9 1.1-.2.2-.3.2-.6.1-1.8-.9-3-1.6-4.2-3.6-.3-.5.3-.5.8-1.6.1-.2 0-.4 0-.5l-1-2.3c-.2-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1 1-1 2.5s1.1 2.9 1.2 3.1c.2.2 2.2 3.3 5.3 4.7 2 .8 2.7.9 3.7.8.6-.1 1.8-.8 2.1-1.5.3-.7.3-1.4.2-1.5-.1-.2-.3-.2-.6-.4z"
    ></path>
  </svg>
  <span class="sr-only">WhatsApp</span>
</a>

<style>
  .whatsapp-float {
    position: fixed;
    right: 1rem;
    bottom: 1rem;
    z-index: 70;
    display: inline-grid;
    place-items: center;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: #25d366;
    color: #fff;
    box-shadow: 0 8px 24px -6px rgba(0, 0, 0, 0.4);
  }
  .whatsapp-float:hover {
    filter: brightness(0.96);
  }
  /* Lift above the mobile sticky CTA bar so they don't overlap. */
  @media (max-width: 899px) {
    .whatsapp-float {
      bottom: 5rem;
    }
  }
</style>
