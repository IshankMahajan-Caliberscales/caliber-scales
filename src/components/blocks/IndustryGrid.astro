---
/**
 * IndustryGrid — compact grid of industry links (spec B5). Defaults to the full
 * INDUSTRIES list; pass `items` to override (e.g. a subset).
 */
import { INDUSTRIES, type CategoryCard } from '@lib/catalog';

interface Props {
  items?: CategoryCard[];
}

const { items = INDUSTRIES } = Astro.props;
---

<ul class="industry-grid">
  {
    items.map((item) => (
      <li>
        <a href={item.href} class="industry-card">
          <span class="industry-title">{item.title}</span>
          <span class="industry-blurb">{item.blurb}</span>
        </a>
      </li>
    ))
  }
</ul>

<style>
  .industry-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }
  .industry-card {
    display: block;
    padding: 1rem 1.1rem;
    background: #fff;
    border: 1px solid #e4e9ee;
    border-left: 3px solid var(--color-accent);
    border-radius: var(--radius-card);
    text-decoration: none;
    transition: background-color 0.15s ease, border-color 0.15s ease;
  }
  .industry-card:hover {
    background: var(--color-surface);
  }
  .industry-title {
    display: block;
    font-weight: 500;
    color: var(--color-navy);
  }
  .industry-blurb {
    display: block;
    margin-top: 0.2rem;
    font-size: 0.88rem;
    color: var(--color-steel);
  }
  @media (min-width: 600px) {
    .industry-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 960px) {
    .industry-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
