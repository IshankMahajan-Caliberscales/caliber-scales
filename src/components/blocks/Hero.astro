---
/**
 * Hero — page headline block. Renders the page's single <h1>. Optional eyebrow,
 * lede, primary/secondary CTAs (defaults to Quote / WhatsApp / Call), and an
 * optional image. Used on Home and as the top of hub/landing pages.
 */
import { whatsappLink, telLink, CONTACT } from '@lib/site';

interface Props {
  eyebrow?: string;
  title: string;
  lede?: string;
  /** Show the default Quote/WhatsApp/Call CTA row. */
  showCtas?: boolean;
  image?: string;
  imageAlt?: string;
  /**
   * How the hero image sits in its fixed 16:10 frame.
   *  • 'cover'   (default) — fills edge-to-edge; for 16:10 art (branded covers,
   *    landscape photos) so nothing shows around it.
   *  • 'contain' — whole image always visible, never cropped, on a light panel;
   *    use for product photos that vary in shape (square, tall, wide).
   */
  imageFit?: 'cover' | 'contain';
}

const {
  eyebrow,
  title,
  lede,
  showCtas = true,
  image,
  imageAlt = '',
  imageFit = 'cover',
} = Astro.props;
---

<section class="hero">
  <div class:list={['container-page', 'hero-inner', { 'has-image': !!image }]}>
    <div class="hero-copy">
      {eyebrow && <p class="eyebrow">{eyebrow}</p>}
      <h1>{title}</h1>
      {lede && <p class="lede">{lede}</p>}
      {
        showCtas && (
          <div class="hero-cta">
            <a href="/contact/" class="btn btn-primary">Request a quote</a>
            <a href={whatsappLink()} class="btn btn-whatsapp" rel="noopener" data-cta="whatsapp">
              WhatsApp us
            </a>
            <a href={telLink()} class="btn btn-secondary" data-cta="call">
              Call {CONTACT.phoneDisplay}
            </a>
          </div>
        )
      }
      <slot />
    </div>
    {
      image && (
        <div class:list={['hero-media', `fit-${imageFit}`]}>
          <img
            src={image}
            alt={imageAlt}
            width="1200"
            height="750"
            fetchpriority="high"
            decoding="async"
          />
        </div>
      )
    }
  </div>
</section>

<style>
  .hero {
    background: linear-gradient(180deg, #fff 0%, var(--color-surface) 100%);
  }
  .hero-inner {
    padding-block: clamp(1.75rem, 4.5vw, 3.25rem);
  }
  .hero-copy {
    max-width: 60ch;
  }
  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--color-accent);
    margin: 0 0 0.75rem;
  }
  h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    margin: 0 0 1rem;
  }
  .lede {
    font-size: 1.15rem;
    color: var(--color-steel);
    margin: 0 0 1.75rem;
  }
  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  /* Fixed-ratio frame so every hero is the same shape on every screen and the
     image can never distort. The 16:10 ratio matches the branded covers and
     generated imagery, so they fill edge-to-edge; off-ratio photos are centred
     and gently cover-cropped (never stretched). Navy backdrop = no stray edges. */
  .hero-media {
    aspect-ratio: 16 / 10;
    width: 100%;
    border-radius: var(--radius-card);
    overflow: hidden;
    box-shadow: 0 18px 44px -28px rgba(12, 45, 82, 0.55);
  }
  .hero-media img {
    width: 100%;
    height: 100%;
    object-position: center;
    display: block;
  }
  /* cover: 16:10 art fills the frame; navy backdrop hides any sub-pixel edge. */
  .hero-media.fit-cover {
    background: linear-gradient(135deg, var(--color-navy) 0%, var(--color-navy-600) 100%);
  }
  .hero-media.fit-cover img {
    object-fit: cover;
  }
  /* contain: any-shape product photo shown whole, never cropped, on a light
     panel with a hairline border so the framing reads as intentional. */
  .hero-media.fit-contain {
    background: linear-gradient(135deg, #fff 0%, var(--color-surface) 100%);
    border: 1px solid #e4e9ee;
  }
  .hero-media.fit-contain img {
    object-fit: contain;
    padding: clamp(0.75rem, 3vw, 1.75rem);
    box-sizing: border-box;
  }
  @media (min-width: 900px) {
    .hero-inner.has-image {
      display: grid;
      grid-template-columns: 1.1fr 0.9fr;
      gap: 2.5rem;
      align-items: center;
    }
  }
</style>
