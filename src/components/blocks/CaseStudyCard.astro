---
/**
 * CaseStudyCard — summary card linking to a case study (spec B5).
 */
interface Props {
  title: string;
  href: string;
  industry: string;
  summary: string;
  image?: string;
  clientName?: string;
}

const { title, href, industry, summary, image, clientName } = Astro.props;
---

<a href={href} class="cs-card">
  {
    image && (
      <span class="cs-media">
        <img src={image} alt="" loading="lazy" width="400" height="240" />
      </span>
    )
  }
  <span class="cs-body">
    <span class="cs-meta">
      {industry}
      {clientName && clientName !== 'Confidential' ? ` · ${clientName}` : ''}
    </span>
    <span class="cs-title">{title}</span>
    <span class="cs-summary">{summary}</span>
    <span class="cs-link" aria-hidden="true">Read case study →</span>
  </span>
</a>

<style>
  .cs-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    background: #fff;
    border: 1px solid #e4e9ee;
    border-radius: var(--radius-card);
    overflow: hidden;
    text-decoration: none;
    transition: box-shadow 0.15s ease, transform 0.15s ease;
  }
  .cs-card:hover {
    box-shadow: 0 14px 30px -18px rgba(12, 45, 82, 0.45);
    transform: translateY(-2px);
  }
  .cs-media img {
    width: 100%;
    height: auto;
    object-fit: cover;
    display: block;
  }
  .cs-body {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding: 1.1rem 1.2rem 1.3rem;
  }
  .cs-meta {
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-accent);
    font-weight: 500;
  }
  .cs-title {
    font-weight: 500;
    font-size: 1.1rem;
    color: var(--color-navy);
    line-height: 1.3;
  }
  .cs-summary {
    color: var(--color-steel);
    font-size: 0.92rem;
    line-height: 1.5;
  }
  .cs-link {
    margin-top: 0.35rem;
    color: var(--color-accent);
    font-weight: 500;
    font-size: 0.9rem;
  }
</style>
